---
import '../../styles/global.css';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { SEO } from 'astro-seo';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import homeInterface from '../../assets/home-v3.1.2.avif';
import downloadInterface from '../../assets/download-v3.1.2.avif';
import editorInterface from '../../assets/editor-de-video-v3.1.2.avif';
import themeSettings from '../../assets/config-tema-v3.1.2.avif';
import languageSettings from '../../assets/config-idioma-3.1.2.avif';
import kingoIcon from '../../assets/kingo.ico';
import { CURRENT_APP_VERSION } from '../../config/release';

const { canonical = "https://downkingo.com/", hreflangEn = "https://downkingo.com/", hreflangPt = "https://downkingo.com/pt/" } = Astro.props;

const assetUrl = (src: string) => new URL(src, "https://downkingo.com").href;

const faqItems = [
  {
    question: "What is DownKingo?",
    answer: "DownKingo is a free, open-source desktop media app. Version 3.1.2 downloads video, audio, images, and social media carousels; converts media; edits clips and captions; and transcribes audio or video locally.",
  },
  {
    question: "Which operating systems support the current version?",
    answer: "DownKingo 3.1.2 is currently available for 64-bit Windows 10 and Windows 11. Legacy Linux and macOS builds remain on the download page while current cross-platform releases are prepared.",
  },
  {
    question: "Which engine does DownKingo use?",
    answer: "DownKingo uses yt-dlp for media extraction and FFmpeg for remuxing, conversion, trimming, and styled captions. Optional aria2c turbo mode adds segmented downloads for compatible sources.",
  },
  {
    question: "Is DownKingo private?",
    answer: "DownKingo has no usage telemetry. Downloads, conversion, editing, and transcription run on your computer. Network access is still required to fetch media, releases, and optional components such as Whisper models.",
  },
  {
    question: "Does transcription work offline?",
    answer: "Yes. After you install a Whisper.cpp model, audio and video transcription runs locally without sending the media to a transcription service.",
  },
  {
    question: "Is downloading videos legal?",
    answer: "DownKingo is a media tool. Only download content you own or are authorized to save, and follow the applicable laws and platform terms.",
  },
];

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://downkingo.com/#organization",
  name: "DownKingo",
  url: "https://downkingo.com/",
  logo: {
    "@type": "ImageObject",
    url: "https://downkingo.com/kingo.webp",
  },
  sameAs: ["https://github.com/down-kingo/downkingo"],
};

const softwareApplicationSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "@id": "https://downkingo.com/#software",
  name: "DownKingo",
  url: "https://downkingo.com/",
  downloadUrl: "https://github.com/down-kingo/downkingo/releases/latest/download/DownKingo.exe",
  codeRepository: "https://github.com/down-kingo/downkingo",
  license: "https://github.com/down-kingo/downkingo/blob/v3/LICENSE",
  operatingSystem: ["Windows 10", "Windows 11"],
  applicationCategory: "MultimediaApplication",
  applicationSubCategory: "Open-source video downloader and media toolkit",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  description: "A free, open-source desktop app for downloading media, converting files, editing clips and captions, and transcribing audio or video locally.",
  featureList: "Video and audio downloads, persistent download queue, media conversion, pre-download video editing, styled captions, local Whisper transcription, download history, optional aria2c acceleration",
  fileSize: "83 MB",
  softwareVersion: CURRENT_APP_VERSION,
  datePublished: "2026-07-16",
  releaseNotes: "https://github.com/down-kingo/downkingo/releases/tag/v3.1.2",
  isAccessibleForFree: true,
  image: "https://downkingo.com/og-image.png",
  screenshot: [
    assetUrl(homeInterface.src),
    assetUrl(downloadInterface.src),
    assetUrl(editorInterface.src),
  ],
  author: { "@id": "https://downkingo.com/#organization" },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://downkingo.com/#website",
  name: "DownKingo",
  url: "https://downkingo.com/",
  publisher: { "@id": "https://downkingo.com/#organization" },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth selection:bg-primary/30 selection:text-white">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Console Filter: Removes third-party/extension logs -->
    <script is:inline src="/scripts/console-filter.js" defer></script>
    <SEO
      title="DownKingo — Open Source Video Downloader & Media Toolkit"
      description="Download media, edit clips, convert files, and transcribe audio locally with DownKingo, a free open-source desktop app for Windows."
      canonical={canonical}
      openGraph={{
        basic: {
          title: "DownKingo — Open Source Video Downloader & Media Toolkit",
          type: "website",
          image: "https://downkingo.com/og-image.png",
          url: canonical
        },
        optional: {
          description: "A free, open-source desktop app for downloading media, editing clips and captions, converting files, and transcribing locally."
        }
      }}
      twitter={{
        card: "summary_large_image",
        site: "@downkingo",
        creator: "@downkingo",
        title: "DownKingo — Open Source Video Downloader & Media Toolkit",
        description: "Download media, edit clips and captions, convert files, and transcribe locally with the free, open-source DownKingo desktop app.",
        image: "https://downkingo.com/og-image.png"
      }}
      extend={{
        meta: [
          { name: "theme-color", content: "#050505" },
          { property: "og:locale", content: "en_US" },
          { property: "og:site_name", content: "DownKingo" },
          { property: "og:image:width", content: "1861" },
          { property: "og:image:height", content: "933" },
          { property: "og:image:type", content: "image/png" },
          { property: "og:image:alt", content: "DownKingo open-source desktop media app" }
        ],
        link: [
          { rel: "icon", type: "image/x-icon", href: kingoIcon }
        ]
      }}
    />
    
    <!-- Hreflang Tags -->
    <link rel="alternate" hreflang="en" href={hreflangEn} />
    <link rel="alternate" hreflang="pt-BR" href={hreflangPt} />
    <link rel="alternate" hreflang="x-default" href={hreflangEn} />

    <!-- Preload Critical Fonts (Inter 900/400 + Mono 400/500) to avoid chains -->
    <link rel="preload" href="/fonts/inter-900.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin>

    <!-- JSON-LD SEO: SoftwareApplication -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(softwareApplicationSchema)} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <!-- Preload Critical Assets -->

    
    <!-- Language Auto-Redirect -->
    <script is:inline src="/scripts/lang-redirect.js" defer></script>
</head>
<body class="bg-page text-swiss antialiased overflow-x-hidden relative" id="body">

    <!-- Noise Texture -->


    <!-- Navigation -->
    <Navigation lang="en" currentPage="home" />

    <!-- Main Content -->
    <main class="relative z-10 w-full overflow-hidden">
        
        <!-- Hero Section -->
        <section class="relative min-h-[100svh] flex flex-col items-center justify-center pt-24 px-6 overflow-hidden">
            <!-- Background Elements -->
            <div class="absolute inset-0 bg-grid-premium opacity-20 pointer-events-none"></div>
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary/20 blur-[120px] rounded-full opacity-20 pointer-events-none mix-blend-screen animate-pulse duration-[5000ms]"></div>
            
            <div class="relative z-10 translate-y-8 text-center max-w-5xl mx-auto space-y-10 md:translate-y-10">
                <!-- Main Title -->
                <!-- Semantic H1 for SEO (Hidden) -->
                <h1 class="sr-only">Download, Convert and Transcribe with Kingo</h1>

                <!-- Visual Title Animation (Aria-Hidden) -->
                <div aria-hidden="true" class="font-black tracking-tighter uppercase leading-none text-white drop-shadow-2xl text-center mx-auto max-w-full flex flex-col items-center gap-2 md:gap-4">
                    <span id="rotating-text" class="block transition-all duration-500 ease-out h-[1.1em] text-5xl sm:text-7xl md:text-8xl lg:text-9xl">DOWNLOAD</span>
                    <span class="text-transparent bg-clip-text bg-gradient-to-b from-white to-white/40 block text-3xl sm:text-5xl md:text-6xl lg:text-7xl">WITH KINGO</span>
                </div>

                <p class="mx-auto max-w-3xl text-base leading-relaxed text-white/65 md:text-lg">
                    DownKingo is a desktop app for downloading video, audio, images, and social media carousels — with a converter, video editor, styled captions, and private local transcription in the same workflow.
                </p>
                
                <!-- Actions -->
                <div class="flex flex-col md:flex-row items-center justify-center gap-6 pt-8">
                     <a id="hero-download-btn" href="/download/" class="h-14 px-10 bg-white text-black font-black text-sm uppercase tracking-widest hover:bg-gray-200 transition-all rounded-full flex items-center gap-3 hover:scale-105 active:scale-95">
                             <span id="hero-download-text">Download v{CURRENT_APP_VERSION}</span>
                             <Icon id="hero-download-icon" name="lucide:arrow-down" width={20} />
                     </a>
                     <a href="/docs/" class="h-14 px-10 border border-white/20 hover:border-white text-white font-mono text-xs uppercase tracking-widest rounded-full flex items-center gap-3 transition-all hover:bg-white/5 hover:scale-105 active:scale-95">
                        <Icon name="lucide:book-open" width={20} />
                        <span>Documentation</span>
                     </a>
                </div>
            </div>
            
            <!-- The rotating texts are passed as dataset to let external scripts catch it -->
            <script is:inline src="/scripts/hero-animation.js" defer></script>
        </section>

        <!-- Marquee / Supported Sites -->
        <section class="py-10 border-y border-white/5 bg-black/50 overflow-hidden">
             <div class="relative w-full overflow-hidden text-center">
                 <p class="text-[10px] font-mono uppercase tracking-widest text-muted mb-6">Supported Platforms</p>
                 <div class="flex whitespace-nowrap animate-marquee opacity-60 hover:opacity-100 transition-opacity">
                     <!-- Set 1 -->
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2"><Icon name="simple-icons:youtube" /> YouTube</span>
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2"><Icon name="simple-icons:tiktok" /> TikTok</span>
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2"><Icon name="simple-icons:instagram" /> Instagram</span>
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2"><Icon name="simple-icons:x" /> Twitter / X</span>
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2"><Icon name="simple-icons:soundcloud" /> Soundcloud</span>
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2"><Icon name="simple-icons:twitch" /> Twitch</span>
                     
                     <!-- GLOBO -->
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 13c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm6-3c0 2.37-1.4 4.42-3.46 5.28-.5.21-1.03.38-1.57.49l-.02.01c-.13.03-.27.05-.41.07l-.1.01c-.14.02-.29.04-.44.04-.15 0-.29-.02-.44-.04l-.1-.01c-.14-.02-.28-.04-.41-.07l-.02-.01c-.54-.11-1.07-.28-1.57-.49C7.4 16.42 6 14.37 6 12s1.4-4.42 3.46-5.28c.5-.21 1.03-.38 1.57-.49l.02-.01c.14-.03.28-.05.41-.07l.1-.01c.15-.02.29-.04.44-.04.15 0 .29.02.44.04l.1.01c.14.02.28.04.41.07l.02.01c.54.11 1.07.28 1.57.49C16.6 7.58 18 9.63 18 12z" clip-rule="evenodd"/></svg>
                        Globo
                     </span>

                     <!-- ESPN (Font Simulation: Impact Italic) -->
                     <span class="mx-12 text-lg text-white cursor-default flex items-center gap-2" style="font-family: Impact, sans-serif; font-style: italic; letter-spacing: 1px;">
                        ESPN
                     </span>
                     
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2"><span class="iconify" data-icon="simple-icons:pinterest"></span> Pinterest</span>
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2"><span class="iconify" data-icon="simple-icons:reddit"></span> Reddit</span>
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2"><span class="iconify" data-icon="simple-icons:facebook"></span> Facebook</span>

                     <!-- Set 2 (Duplicate for Loop) -->
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2"><Icon name="simple-icons:youtube" /> YouTube</span>
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2"><Icon name="simple-icons:tiktok" /> TikTok</span>
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2"><Icon name="simple-icons:instagram" /> Instagram</span>
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2"><Icon name="simple-icons:x" /> Twitter / X</span>
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2"><Icon name="simple-icons:soundcloud" /> Soundcloud</span>
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2"><Icon name="simple-icons:twitch" /> Twitch</span>
                     
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 13c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm6-3c0 2.37-1.4 4.42-3.46 5.28-.5.21-1.03.38-1.57.49l-.02.01c-.13.03-.27.05-.41.07l-.1.01c-.14.02-.29.04-.44.04-.15 0-.29-.02-.44-.04l-.1-.01c-.14-.02-.28-.04-.41-.07l-.02-.01c-.54-.11-1.07-.28-1.57-.49C7.4 16.42 6 14.37 6 12s1.4-4.42 3.46-5.28c.5-.21 1.03-.38 1.57-.49l.02-.01c.14-.03.28-.05.41-.07l.1-.01c.15-.02.29-.04.44-.04.15 0 .29.02.44.04l.1.01c.14.02.28.04.41.07l.02.01c.54.11 1.07.28 1.57.49C16.6 7.58 18 9.63 18 12z" clip-rule="evenodd"/></svg>
                        Globo
                     </span>

                     <!-- ESPN (Font Simulation: Impact Italic) -->
                     <span class="mx-12 text-lg text-white cursor-default flex items-center gap-2" style="font-family: Impact, sans-serif; font-style: italic; letter-spacing: 1px;">
                        ESPN
                     </span>
                     
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2"><span class="iconify" data-icon="simple-icons:pinterest"></span> Pinterest</span>
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2"><span class="iconify" data-icon="simple-icons:reddit"></span> Reddit</span>
                     <span class="mx-12 text-sm font-bold uppercase text-white cursor-default flex items-center gap-2"><span class="iconify" data-icon="simple-icons:facebook"></span> Facebook</span>
                 </div>
             </div>
        </section>

        <!-- DATA / FEATURES Section -->
        <section id="features" class="py-32 px-6 max-w-7xl mx-auto border-b border-white/5">
            <div class="space-y-32">
                
                <!-- FEATURE BLOCK 1: Architecture + Screen -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                    
                    <!-- Text Content -->
                    <div class="space-y-8 reveal-wrapper">
                        <span class="inline-block mb-4 font-mono text-xs text-primary uppercase tracking-widest border border-primary/20 bg-primary/5 px-2 py-1 rounded">DownKingo 3.1.2</span>
                        <h2 class="text-4xl md:text-6xl font-black uppercase tracking-tight text-white">One App. {' '}<br />{' '} Three Workflows.</h2>
                        <p class="max-w-lg text-sm leading-relaxed text-muted">
                            Download media, convert files, and transcribe audio without sending your work through a chain of browser tools. DownKingo keeps the core workflow in one open-source desktop app.
                        </p>
                        
                        <ul class="space-y-6 pt-4">
                            <li class="flex items-start gap-4 group">
                                <div class="p-2 rounded-lg bg-white/5 group-hover:bg-primary/10 transition-colors">
                                    <Icon name="simple-icons:opensourceinitiative" class="text-primary" width={20} />
                                </div>
                                <div>
                                    <h3 class="text-white font-bold text-sm uppercase">Open Source by Design</h3>
                                    <p class="text-xs text-muted mt-1 leading-relaxed">The source, releases, and public roadmap are available on GitHub under the MIT license.</p>
                                </div>
                            </li>
                            <li class="flex items-start gap-4 group">
                                <div class="p-2 rounded-lg bg-white/5 group-hover:bg-primary/10 transition-colors">
                                    <Icon name="lucide:hard-drive" class="text-primary" width={20} />
                                </div>
                                <div>
                                    <h3 class="text-white font-bold text-sm uppercase">Local-First Tools</h3>
                                    <p class="text-xs text-muted mt-1 leading-relaxed">Conversion, editing, caption rendering, and Whisper transcription run on your computer.</p>
                                </div>
                            </li>
                        </ul>
                    </div>

                    <!-- Visual Content: App Screenshot -->
                    <div class="relative group reveal-wrapper perspective-container">
                        <!-- Glow Effect -->
                        <div class="absolute -inset-1 bg-gradient-to-r from-primary/20 to-purple-500/20 rounded-xl blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                        
                        <!-- Image Container -->
                        <div class="relative rounded-xl overflow-hidden border border-white/10 shadow-2xl bg-[#050505] rotate-3d hover:transition-transform duration-500">
                             <!-- Mac/Window Controls Decoration -->
                             <div class="h-8 bg-[#111] border-b border-white/5 flex items-center px-4 gap-2">
                                <div class="w-3 h-3 rounded-full bg-red-500/20 text-red-500 flex items-center justify-center text-[8px] opacity-50"></div>
                                <div class="w-3 h-3 rounded-full bg-yellow-500/20 text-yellow-500 opacity-50"></div>
                                <div class="w-3 h-3 rounded-full bg-green-500/20 text-green-500 opacity-50"></div>
                                <div class="ml-auto text-[10px] font-mono text-muted/50">downkingo-v3</div>
                             </div>
                             
                             <Image
                                src={homeInterface}
                                alt="DownKingo v3.1.2 dashboard with Downloads, Media Converter, and Transcriber"
                                class="w-full h-auto object-cover opacity-90 group-hover:opacity-100 transition-opacity"
                                widths={[480, 768, 1024]}
                                sizes="(max-width: 1024px) 100vw, 50vw"
                                loading="lazy"
                                decoding="async"
                             />
                             
                             <!-- Overlay Gradient -->
                             <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-transparent to-transparent opacity-20 pointer-events-none"></div>
                        </div>
                    </div>
                </div>

                <!-- FEATURE BLOCK 2: Terminal + Capabilities -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                    
                    <!-- Visual Content: Terminal (Left) -->
                    <div class="relative w-full perspective-container order-2 lg:order-1">
                        <!-- Terminal Window -->
                        <div class="bg-[#09090b] border border-white/10 rounded-lg overflow-hidden shadow-2xl reveal-wrapper rotate-3d-reverse font-mono text-[10px] md:text-xs leading-relaxed select-none group">
                            
                            <!-- Terminal Header -->
                            <div class="flex items-center justify-between px-4 py-2 bg-[#111113] border-b border-white/5 transition-colors group-hover:bg-[#1a1a1c]">
                                <div class="flex items-center gap-2 text-muted">
                                    <Icon name="lucide:terminal-square" width={14} />
                                    <span class="uppercase tracking-widest text-[10px] font-bold">Console</span>
                                </div>
                                <div class="flex gap-2 opacity-50">
                                    <Icon name="lucide:lock" width={12} />
                                    <Icon name="lucide:maximize" width={12} />
                                    <Icon name="lucide:chevron-down" width={12} />
                                </div>
                            </div>

                            <!-- Terminal Content -->
                            <div class="p-4 space-y-3 h-[400px] overflow-hidden relative">
                                <!-- Background Grid Effect inside terminal -->
                                <div class="absolute inset-0 bg-grid-premium opacity-5 pointer-events-none"></div>

                                <!-- Lines -->
                                <div class="flex gap-3 text-cyan-500/80 animate-fade-in-up" style="animation-delay: 100ms;">
                                    <Icon name="lucide:info" class="mt-0.5" width={12} />
                                    <span>Fetching information...</span>
                                    <span class="ml-auto opacity-30">00:04:34</span>
                                </div>

                                <div class="flex gap-3 text-emerald-500 bg-emerald-500/5 py-1 -mx-2 px-2 rounded animate-fade-in-up" style="animation-delay: 200ms;">
                                    <Icon name="lucide:check" class="mt-0.5" width={12} />
                                    <span>"you need to learn FFmpeg RIGHT NOW!!" found</span>
                                    <span class="ml-auto opacity-30">00:04:43</span>
                                </div>

                                <div class="flex gap-3 text-muted animate-fade-in-up" style="animation-delay: 300ms;">
                                    <Icon name="lucide:info" class="mt-0.5" width={12} />
                                    <span class="truncate">Extracting URL: https://www.youtube.com/watch?v=...</span>
                                    <span class="ml-auto opacity-30">00:05:00</span>
                                </div>

                                <div class="flex gap-3 text-muted animate-fade-in-up" style="animation-delay: 400ms;">
                                    <Icon name="lucide:info" class="mt-0.5" width={12} />
                                    <span>Downloading 1 format(s): 137+140-9</span>
                                    <span class="ml-auto opacity-30">00:05:03</span>
                                </div>

                                <!-- Progress Bar 1 -->
                                <div class="space-y-1 pt-2 animate-fade-in-up" style="animation-delay: 600ms;">
                                    <div class="flex gap-3 text-cyan-400">
                                        <Icon name="lucide:loader-2" class="mt-0.5" width={12} />
                                        <span>Downloading video...</span>
                                        <span class="ml-auto text-cyan-400">99%</span>
                                        <span class="text-cyan-400/50">5.7MiB</span>
                                    </div>
                                    <div class="h-1 w-full bg-white/5 rounded-full overflow-hidden">
                                        <div class="h-full bg-cyan-500 w-[99%] shadow-[0_0_10px_rgba(6,182,212,0.5)]"></div>
                                    </div>
                                </div>

                                <!-- Progress Bar 2 -->
                                <div class="space-y-1 pt-2 animate-fade-in-up" style="animation-delay: 800ms;">
                                    <div class="flex gap-3 text-cyan-400">
                                        <Icon name="lucide:loader-2" class="mt-0.5" width={12} />
                                        <span>Downloading audio...</span>
                                        <span class="ml-auto text-cyan-400">93%</span>
                                        <span class="text-cyan-400/50">751KiB</span>
                                    </div>
                                    <div class="h-1 w-full bg-white/5 rounded-full overflow-hidden">
                                        <div class="h-full bg-cyan-500 w-[93%] shadow-[0_0_10px_rgba(6,182,212,0.5)]"></div>
                                    </div>
                                </div>

                                <div class="flex gap-3 text-purple-400 pt-2 animate-fade-in-up" style="animation-delay: 1000ms;">
                                    <Icon name="lucide:merge" class="mt-0.5" width={12} />
                                    <span>Merging Audio and Video...</span>
                                    <span class="ml-auto opacity-30">00:05:30</span>
                                </div>

                                <div class="flex gap-3 text-amber-500 animate-fade-in-up" style="animation-delay: 1200ms;">
                                    <Icon name="lucide:alert-triangle" class="mt-0.5" width={12} />
                                    <span>Cleaning temp files...</span>
                                    <span class="ml-auto opacity-30">00:05:31</span>
                                </div>

                                <div class="flex gap-3 text-muted/50 animate-fade-in-up" style="animation-delay: 1400ms;">
                                    <Icon name="lucide:file-video" class="mt-0.5" width={12} />
                                    <span class="truncate">[VideoRemuxer] Not remuxing media file... already is in target format mp4</span>
                                </div>
                                
                                <div class="flex gap-3 text-rose-400 animate-fade-in-up" style="animation-delay: 1600ms;">
                                    <Icon name="lucide:image" class="mt-0.5" width={12} />
                                    <span>Processing thumbnail...</span>
                                </div>
                                
                                <!-- Success State -->
                                <div class="flex flex-col gap-2 animate-fade-in-up" style="animation-delay: 1800ms;">
                                    <div class="flex gap-3 text-emerald-400 font-bold">
                                        <Icon name="lucide:check-circle-2" class="mt-0.5" width={12} />
                                        <span>Download Completed!</span>
                                        <span class="ml-auto opacity-50 font-normal">00:05:35</span>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>

                    <!-- Text Content -->
                    <div class="space-y-8 reveal-wrapper order-1 lg:order-2">
                        <span class="inline-block mb-4 font-mono text-xs text-indigo-400 uppercase tracking-widest border border-indigo-500/20 bg-indigo-500/5 px-2 py-1 rounded">Open Source Video Downloader</span>
                        <h2 class="text-4xl md:text-6xl font-black uppercase tracking-tight text-white">Download With {' '}<br />{' '} Control.</h2>
                        <p class="text-muted max-w-md text-sm leading-relaxed">
                            Paste a link, inspect the media, choose video or audio and the available quality, then send the job to a persistent queue you can follow or cancel.
                        </p>
                         <ul class="space-y-6 pt-4">
                            <li class="flex items-start gap-4 group">
                                <div class="p-2 rounded-lg bg-white/5 group-hover:bg-indigo-500/10 transition-colors">
                                    <Icon name="lucide:layers" class="text-indigo-400" width={20} />
                                </div>
                                <div>
                                    <h3 class="text-white font-bold text-sm uppercase">Video, Audio &amp; Images</h3>
                                    <p class="text-xs text-muted mt-1 leading-relaxed">Handle common video and audio formats plus compatible images and social media carousels.</p>
                                </div>
                            </li>
                            <li class="flex items-start gap-4 group">
                                <div class="p-2 rounded-lg bg-white/5 group-hover:bg-indigo-500/10 transition-colors">
                                    <Icon name="lucide:terminal" class="text-indigo-400" width={20} />
                                </div>
                                <div>
                                    <h3 class="text-white font-bold text-sm uppercase">yt-dlp + Optional aria2c</h3>
                                    <p class="text-xs text-muted mt-1 leading-relaxed">Use yt-dlp coverage and enable segmented aria2c downloads when the source supports them.</p>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- FEATURE BLOCK 3: Video Editor + Captions -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                    
                    <!-- Text Content -->
                    <div class="space-y-8 reveal-wrapper">
                        <span class="inline-block mb-4 font-mono text-xs text-rose-400 uppercase tracking-widest border border-rose-500/20 bg-rose-500/5 px-2 py-1 rounded">Built-in Video Editor</span>
                        <h2 class="text-4xl md:text-6xl font-black uppercase tracking-tight text-white">Edit Before {' '}<br />{' '} You Download.</h2>
                        <p class="text-muted max-w-md text-sm leading-relaxed">
                            Trim unwanted sections and prepare captions before the final file is rendered, so the download arrives closer to the result you actually need.
                        </p>
                        <ul class="space-y-6 pt-4">
                            <li class="flex items-start gap-4 group">
                                <div class="p-2 rounded-lg bg-white/5 group-hover:bg-rose-500/10 transition-colors">
                                    <Icon name="lucide:mic" class="text-rose-400" width={20} />
                                </div>
                                <div>
                                    <h3 class="text-white font-bold text-sm uppercase">Timeline Editing</h3>
                                    <p class="text-xs text-muted mt-1 leading-relaxed">Preview the video, split the timeline, remove sections, and review the final duration.</p>
                                </div>
                            </li>
                            <li class="flex items-start gap-4 group">
                                <div class="p-2 rounded-lg bg-white/5 group-hover:bg-rose-500/10 transition-colors">
                                    <Icon name="lucide:file-text" class="text-rose-400" width={20} />
                                </div>
                                <div>
                                    <h3 class="text-white font-bold text-sm uppercase">Styled Captions</h3>
                                    <p class="text-xs text-muted mt-1 leading-relaxed">Import available subtitles or use local Whisper, revise the text, and burn styled captions into the video.</p>
                                </div>
                            </li>
                        </ul>
                    </div>

                    <!-- Visual Content: Current Editor Screenshot -->
                    <div class="relative group reveal-wrapper perspective-container">
                        <div class="absolute -inset-1 bg-gradient-to-r from-rose-500/20 to-orange-500/20 rounded-xl blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                        <div class="relative rounded-xl overflow-hidden border border-white/10 shadow-2xl bg-[#09090b] hover:transform hover:scale-[1.02] transition-transform duration-500">
                             <Image
                                src={editorInterface}
                                alt="DownKingo v3.1.2 video editor with timeline and caption controls"
                                class="w-full h-auto object-cover opacity-90 group-hover:opacity-100 transition-opacity"
                                widths={[480, 768, 1024]}
                                sizes="(max-width: 1024px) 100vw, 50vw"
                                loading="lazy"
                                decoding="async"
                             />
                             <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-transparent to-transparent opacity-20 pointer-events-none"></div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- HOW TO USE Section (SEO Content Expansion) -->
        <section class="py-24 px-6 max-w-7xl mx-auto border-b border-white/5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
                <div class="space-y-8 reveal-wrapper">
                    <span class="inline-block font-mono text-xs text-secondary max-w-[200px] uppercase tracking-widest border border-secondary/20 bg-secondary/5 px-2 py-1 rounded mb-4">Quick Guide</span>
                    <h2 class="text-4xl md:text-5xl font-black uppercase tracking-tight text-white mb-6">How to Download Videos {' '}<br />{' '} in 3 Simple Steps.</h2>
                    
                    <div class="space-y-8 relative pl-8 border-l border-white/10">
                        <div class="relative group">
                            <span class="absolute -left-[41px] top-0 flex h-6 w-6 items-center justify-center rounded-full bg-secondary text-black font-bold text-xs ring-4 ring-[#050505]">1</span>
                            <h3 class="text-xl font-bold text-white mb-2">Copy the Link</h3>
                            <p class="text-muted text-sm leading-relaxed">
                                Navigate to your favorite video on YouTube, Instagram, TikTok, or Twitter and copy the URL from the address bar or share button.
                            </p>
                        </div>
                        <div class="relative group">
                            <span class="absolute -left-[41px] top-0 flex h-6 w-6 items-center justify-center rounded-full bg-secondary/50 text-white font-bold text-xs ring-4 ring-[#050505] group-hover:bg-secondary group-hover:text-black transition-colors">2</span>
                            <h3 class="text-xl font-bold text-white mb-2">Paste in DownKingo</h3>
                            <p class="text-muted text-sm leading-relaxed">
                                Open the DownKingo app. It will automatically detect the copied link from your clipboard. Select your desired format (MP4 or MP3).
                            </p>
                        </div>
                        <div class="relative group">
                            <span class="absolute -left-[41px] top-0 flex h-6 w-6 items-center justify-center rounded-full bg-secondary/50 text-white font-bold text-xs ring-4 ring-[#050505] group-hover:bg-secondary group-hover:text-black transition-colors">3</span>
                            <h3 class="text-xl font-bold text-white mb-2">Instant Download</h3>
                            <p class="text-muted text-sm leading-relaxed">
                                Add the job to the queue and follow its progress. DownKingo downloads the selected streams, processes them locally, and saves the finished file to your chosen folder.
                            </p>
                        </div>
                    </div>

                    <a href="/download/" class="inline-flex items-center gap-3 bg-white text-black px-8 py-4 rounded-full font-bold uppercase tracking-widest text-xs hover:scale-105 transition-transform mt-4">
                        Get Started <Icon name="lucide:arrow-right" class="w-4 h-4" />
                    </a>
                </div>
                
                <div class="reveal-wrapper order-first md:order-last">
                    <div class="p-8 border border-white/10 bg-white/[0.02] rounded-2xl">
                        <div class="mb-8 overflow-hidden rounded-xl border border-white/10 bg-black">
                            <Image
                                src={downloadInterface}
                                alt="DownKingo v3.1.2 download screen with video, audio, quality, caption, and editor controls"
                                class="h-auto w-full"
                                widths={[480, 768, 1024]}
                                sizes="(max-width: 768px) 100vw, 50vw"
                                loading="lazy"
                                decoding="async"
                            />
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-6 uppercase tracking-tight">A desktop workflow, not another converter tab.</h3>
                        <p class="text-muted text-sm leading-relaxed mb-6">
                            DownKingo keeps downloads, the persistent queue, local history, media conversion, editing, captions, and transcription together. You can inspect the open-source code and see what runs on your machine.
                        </p>
                        <p class="text-muted text-sm leading-relaxed mb-6">
                            Version {CURRENT_APP_VERSION} is the current Windows release. Linux and macOS builds available today are legacy versions while the current cross-platform packages are prepared.
                        </p>
                        <p class="text-muted text-sm leading-relaxed">
                            Development remains public: requested features and progress are tracked on the <a href="https://github.com/orgs/down-kingo/projects/2" target="_blank" rel="noopener noreferrer" class="text-white underline decoration-white/30 underline-offset-4 hover:decoration-white">public roadmap</a>.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- OPEN BY DESIGN SECTION -->
        <section id="build-in-public" class="py-32 px-6 border-b border-white/5 overflow-hidden relative">
            <!-- Background Noise/Glow -->
            <div class="absolute top-0 right-0 w-1/2 h-full bg-primary/5 blur-3xl rounded-full opacity-20 pointer-events-none"></div>

            <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <!-- Text Side -->
                <div class="space-y-8 reveal-wrapper z-10">
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-green-500/20 bg-green-500/5 text-green-400 font-mono text-xs uppercase tracking-widest">
                        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                        Your app, your setup
                    </div>
                    <h2 class="text-5xl md:text-7xl font-black uppercase tracking-tight text-white leading-[1.1]">
                        Open By {' '}<br />{' '} <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-white/50">Design.</span>
                    </h2>
                    <p class="text-muted text-lg leading-relaxed max-w-md">
                        The code is public, usage telemetry is absent, and the roadmap is visible. Inside the app, you can also choose the theme, accent, navigation layout, and one of five interface languages so the workspace feels like yours.
                    </p>
                    
                    <!-- Stats / GitHub Integration -->
                    <div class="flex items-center gap-8 pt-4">
                        <div class="flex items-center gap-4">
                            <Icon name="simple-icons:opensourceinitiative" class="text-white" width={40} />
                            <div class="space-y-0.5">
                                <span class="text-2xl font-black text-white block leading-none">100%</span>
                                <p class="text-xs font-mono uppercase text-muted leading-none">Open Source</p>
                            </div>
                        </div>
                        <div class="w-px h-10 bg-white/10"></div>
                        <a href="https://github.com/orgs/down-kingo/projects/2" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 group/roadmap cursor-pointer hover:bg-white/5 p-2 -m-2 rounded-lg transition-all">
                            <Icon name="simple-icons:github" class="text-white group-hover/roadmap:scale-110 transition-transform duration-300" width={40} />
                            <div class="space-y-0.5">
                                <span class="text-2xl font-black text-white block leading-none">GitHub</span>
                                <p class="text-xs font-mono uppercase text-muted leading-none flex items-center gap-1 group-hover/roadmap:text-white transition-colors">
                                    Kanban Board
                                    <Icon name="lucide:arrow-right" class="opacity-0 -translate-x-2 group-hover/roadmap:opacity-100 group-hover/roadmap:translate-x-0 transition-all duration-300" width={12} />
                                </p>
                            </div>
                        </a>
                    </div>
                </div>

                <!-- Visual Side (Creative Composition) -->
                <div class="relative reveal-wrapper lg:translate-x-12 perspective-container">
                    <!-- Main Image (Appearance Settings) -->
                    <div class="relative z-10 rounded-xl overflow-hidden shadow-2xl border border-white/10 bg-[#09090b] lg:rotate-2 hover:rotate-0 transition-transform duration-700">
                        <div class="absolute inset-0 bg-gradient-to-br from-white/5 to-transparent pointer-events-none"></div>
                        <Image
                            src={themeSettings}
                            alt="DownKingo v3.1.2 appearance settings with theme, accent color, and navigation layout controls"
                            class="w-full h-auto opacity-90 hover:opacity-100 transition-opacity"
                            widths={[480, 768, 1024]}
                            sizes="(max-width: 1024px) 100vw, 50vw"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    
                    <!-- Floating Secondary Image (Language Settings) -->
                    <div class="absolute -bottom-12 -left-12 z-20 w-2/3 rounded-xl overflow-hidden shadow-[0_0_50px_rgba(0,0,0,0.5)] border border-white/10 bg-[#09090b] -rotate-3 hover:rotate-0 transition-transform duration-700 delay-100 hidden md:block">
                        <Image
                            src={languageSettings}
                            alt="DownKingo v3.1.2 language settings with Portuguese, English, Spanish, French, and German"
                            class="w-full h-auto opacity-90 hover:opacity-100 transition-opacity"
                            widths={[360, 640, 768]}
                            sizes="33vw"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                </div>
            </div>
        </section>

        <!-- GRID FEATURES -->
        <section id="toolkit" class="py-32 px-6 max-w-7xl mx-auto">
            <div class="text-center mb-20 reveal-wrapper">
                 <h2 class="text-4xl font-black uppercase tracking-tight text-white mb-4">The Toolkit.</h2>
                 <p class="text-muted text-sm font-mono uppercase">Practical tools for the work that happens around a download.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Card 1 -->
                <div class="group border border-white/10 bg-white/[0.02] p-8 rounded-2xl hover:bg-white/[0.04] transition-colors">
                    <div class="mb-6 opacity-50 group-hover:opacity-100 group-hover:text-primary transition-all">
                        <Icon name="lucide:refresh-cw" width={32} />
                    </div>
                    <h3 class="text-lg font-bold text-white mb-2 uppercase">Smart Converter</h3>
                    <p class="text-xs text-muted leading-relaxed font-mono">
                        Built-in FFmpeg wrapper to convert video, audio, and images between formats effortlessly.
                    </p>
                </div>

                 <!-- Card: Local Transcription -->
                 <div class="group border border-white/10 bg-white/[0.02] p-8 rounded-2xl hover:bg-white/[0.04] transition-colors">
                    <div class="mb-6 opacity-50 group-hover:opacity-100 group-hover:text-primary transition-all">
                        <Icon name="lucide:captions" width={32} />
                    </div>
                    <h3 class="text-lg font-bold text-white mb-2 uppercase">Local Transcription</h3>
                    <p class="text-xs text-muted leading-relaxed font-mono">
                        Turn audio or video into text with Whisper.cpp after installing a model. The media stays on your computer.
                    </p>
                </div>

                <!-- Card 2 -->
                <div class="group border border-white/10 bg-white/[0.02] p-8 rounded-2xl hover:bg-white/[0.04] transition-colors">
                    <div class="mb-6 opacity-50 group-hover:opacity-100 group-hover:text-primary transition-all">
                        <Icon name="lucide:shield-check" width={32} />
                    </div>
                    <h3 class="text-lg font-bold text-white mb-2 uppercase">Zero Telemetry</h3>
                    <p class="text-xs text-muted leading-relaxed font-mono">
                         Privacy by design. No tracking servers. Your usage data never leaves your device.
                    </p>
                </div>

                <!-- Card 4 -->
                <div class="group border border-white/10 bg-white/[0.02] p-8 rounded-2xl hover:bg-white/[0.04] transition-colors">
                    <div class="mb-6 opacity-50 group-hover:opacity-100 group-hover:text-primary transition-all">
                        <Icon name="lucide:globe" width={32} />
                    </div>
                    <h3 class="text-lg font-bold text-white mb-2 uppercase">Polyglot</h3>
                    <p class="text-xs text-muted leading-relaxed font-mono">
                        Localized in 5 languages: English, Portuguese, Spanish, French, and German.
                    </p>
                </div>
            </div>
        </section>

        <!-- SUPPORTED FORMATS (SEO Section) -->
        <section class="py-24 px-6 border-t border-white/5 bg-white/[0.01]">
             <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">
                <!-- Text -->
                <div class="space-y-6 reveal-wrapper">
                    <h2 class="text-3xl font-black uppercase tracking-tight text-white">Keep the quality and format that fit the job.</h2>
                    <p class="text-muted leading-relaxed">
                        DownKingo shows the streams available at the source, lets you choose video or audio quality, and uses FFmpeg when the selected tracks need to be joined, remuxed, or converted.
                    </p>
                    <div class="flex flex-wrap gap-2 text-[10px] font-mono uppercase tracking-widest text-primary/60">
                        <span>#OpenSource</span>
                        <span>#LocalWorkflow</span>
                        <span>#NoTelemetry</span>
                    </div>
                </div>

                <!-- Grid -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 reveal-wrapper" style="transition-delay: 100ms;">
                     <div class="p-6 border border-white/5 bg-black/40 rounded-xl hover:border-primary/30 transition-colors">
                        <span class="block text-primary font-bold text-sm mb-2">Video</span>
                        <ul class="text-xs text-muted font-mono space-y-1">
                            <li>MP4 / MKV</li>
                            <li>H.264 / VP9 / MPEG-4</li>
                            <li>WebM / AVI</li>
                            <li>MOV</li>
                        </ul>
                     </div>
                     <div class="p-6 border border-white/5 bg-black/40 rounded-xl hover:border-primary/30 transition-colors">
                        <span class="block text-primary font-bold text-sm mb-2">Audio</span>
                        <ul class="text-xs text-muted font-mono space-y-1">
                            <li>MP3 / AAC</li>
                            <li>M4A / Opus</li>
                            <li>FLAC / WAV</li>
                            <li>OGG</li>
                        </ul>
                     </div>
                     <div class="p-6 border border-white/5 bg-black/40 rounded-xl hover:border-primary/30 transition-colors">
                        <span class="block text-primary font-bold text-sm mb-2">Image & Text</span>
                        <ul class="text-xs text-muted font-mono space-y-1">
                            <li>JPG / PNG / WebP</li>
                            <li>Instagram Carousels</li>
                            <li>Local Transcription</li>
                            <li>TXT / SRT / VTT / DOCX</li>
                        </ul>
                     </div>
                </div>
             </div>
        </section>

        <!-- FAQ Section -->
        <section id="faq" class="py-24 px-6 max-w-4xl mx-auto border-t border-white/5">
            <h2 class="text-2xl font-black uppercase text-white mb-12 text-center tracking-widest">Frequently Asked Questions</h2>
            <div class="space-y-4">
                {faqItems.map((item) => (
                    <details class="group bg-white/[0.02] border border-white/5 rounded-none open:bg-white/[0.04] transition-colors">
                        <summary class="flex items-center justify-between gap-4 p-6 cursor-pointer list-none font-bold text-white text-sm uppercase tracking-wide">
                            {item.question}
                            <Icon name="lucide:chevron-down" class="shrink-0 group-open:rotate-180 transition-transform text-white/50" width={16} />
                        </summary>
                        <div class="px-6 pb-6 text-muted font-mono text-xs leading-relaxed border-t border-white/5 pt-4">
                            {item.answer}
                        </div>
                    </details>
                ))}
            </div>
        </section>

        <!-- Footer -->
        <Footer lang="en" />

    </main>

    <!-- Scroll Reveal Script -->
     <script is:inline src="/scripts/ui-effects.js" defer></script>
</body>
</html>
