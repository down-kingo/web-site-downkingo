---
import '../styles/global.css';
import { SEO } from 'astro-seo';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

import kingoIcon from '../assets/kingo.ico';

interface Props {
	title: string;
	description: string;
	lang?: string;
	canonical?: string;
	opengraph?: any;
    twitter?: any;
    keywords?: string;
    alternateUrls?: { en?: string; pt?: string };
    emitLanguageAlternates?: boolean;
    noindex?: boolean;
    nofollow?: boolean;
    currentPage?: 'home' | 'download' | 'tools' | 'roadmap' | 'docs' | 'online' | 'blog';
}

const {
  title,
  description,
  lang = "pt-BR",
  canonical,
  opengraph,
  twitter,
  keywords,
  alternateUrls,
  emitLanguageAlternates = true,
  noindex = false,
  nofollow = false,
  currentPage = "home",
} = Astro.props;

const language = lang === "pt-BR" || lang === "pt" ? "pt" : "en";
const ogLocale = language === "pt" ? "pt_BR" : "en_US";

// Hreflang logic
const currentPath = Astro.url.pathname;
const isPt = language === "pt";
const baseUrl = "https://downkingo.com";

// The deployed site serves directory-style URLs with a trailing slash.
const removeTrailingSlashForLogic = (value: string) => {
  const stripped = value.replace(/\/+$/, '');
  return stripped || '/';
};

const ensureTrailingSlash = (value: string) => {
  const url = new URL(value, baseUrl);

  if (!url.pathname.endsWith('/')) {
    url.pathname += '/';
  }

  return url.href;
};

// Normalize path: ignore trailing slash for logic
const cleanPath = removeTrailingSlashForLogic(currentPath);

// Build alternate URLs
let enUrl: string;
let ptUrl: string;

if (alternateUrls) {
  // Manual override
  enUrl = alternateUrls.en ? ensureTrailingSlash(alternateUrls.en) : ensureTrailingSlash(cleanPath);
  ptUrl = alternateUrls.pt ? ensureTrailingSlash(alternateUrls.pt) : ensureTrailingSlash(cleanPath);
} else {
  // Standard logic:
  // If we are on PT, strip /pt prefix.
  // If we are on EN (root) or phantom /en/, ensure we point to root.
  
  let pathCore = cleanPath;
  
  if (isPt) {
      // Remove /pt or /pt/ from start
      pathCore = cleanPath.replace(/^\/pt(\/|$)/, "/");
  } else if (cleanPath.startsWith("/en/") || cleanPath === "/en") {
      // Handle phantom /en/ paths by stripping /en
      pathCore = cleanPath.replace(/^\/en(\/|$)/, "/");
  }

  // Ensure pathCore starts with /
  if (!pathCore.startsWith("/")) pathCore = "/" + pathCore;

  // EN URL is always root + core path
  enUrl = baseUrl + (pathCore === "/" ? "" : pathCore);
  
  // PT URL is always root + /pt + core path
  ptUrl = baseUrl + "/pt" + (pathCore === "/" ? "" : pathCore);
}

// Canonical, hreflang and the sitemap must all reference the final 200 URL.
enUrl = ensureTrailingSlash(enUrl);
ptUrl = ensureTrailingSlash(ptUrl);

// If no canonical prop provided, derive it from the detected correct URL for this language
const computedCanonical = canonical ? ensureTrailingSlash(canonical) : (isPt ? ptUrl : enUrl);

const openGraphConfig = opengraph
  ? {
      ...opengraph,
      basic: {
        ...opengraph.basic,
        url: ensureTrailingSlash(opengraph.basic?.url || computedCanonical),
      },
    }
  : opengraph;


// Merge twitter defaults
const twitterConfig = {
  card: "summary_large_image" as const,
  site: "@EMANUELSOARES71",
  creator: "@EMANUELSOARES71",
  ...twitter
};
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth selection:bg-primary/30 selection:text-white">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="generator" content={Astro.generator} />
    
    <!-- Console Filter -->
    <script is:inline src="/scripts/console-filter.js" defer></script>
    
    <SEO
      title={title}
      description={description}
      canonical={computedCanonical}
      noindex={noindex}
      nofollow={nofollow}
      openGraph={openGraphConfig}
      twitter={twitterConfig}
      extend={{
        meta: [
          { name: "keywords", content: keywords },
          { name: "theme-color", content: "#050505" },
          { property: "og:locale", content: ogLocale },
        ],
        link: [
          { rel: "icon", type: "image/x-icon", href: kingoIcon }
        ]
      }}
    />

    <!-- Fonts -->
    <link rel="preload" href="/fonts/jetbrains-mono-400.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/jetbrains-mono-500.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/inter-900.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin>

    <!-- Hreflang Tags -->
    {emitLanguageAlternates && (
      <>
        <link rel="alternate" hreflang="en" href={enUrl} />
        <link rel="alternate" hreflang="pt-BR" href={ptUrl} />
        <link rel="alternate" hreflang="x-default" href={enUrl} />
      </>
    )}

    <ClientRouter />
    <slot name="head" />


</head>
<body class="bg-page text-swiss antialiased overflow-x-hidden relative" id="body">
    <Navigation lang={language} currentPage={currentPage} />

    <main class="relative z-10 w-full overflow-hidden">
        <slot />
    </main>

    <Footer lang={language} />

    <slot name="scripts" />

    <script is:inline src="/scripts/ui-effects.js" defer></script>
</body>
</html>
